# Build artefacts kept out of commits but regenerated by `bun run build`.
node_modules/
*.log
.DS_Store
bun.lockb

# Autonomous build session notes — never committed
AUTONOMOUS-BUILD-NOTES-*.md

# Plugin runtime data (only ever exists in the plugin's data dir on user machines)
state.json
state.json.lock
log.jsonl
log.jsonl.1

# Type-emit / dist (we don't ship pre-compiled JS — Bun runs TS native)
dist/
